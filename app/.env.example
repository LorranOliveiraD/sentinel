# ─────────────────────────────────────────────
# Sentinel V3 — Environment Variables
# ─────────────────────────────────────────────

# ── App ──
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── GitHub ──
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ── Anthropic (Claude) ──
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Google ──
GOOGLE_API_KEY=your_google_api_key_here

# ── Slack ──
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_CHANNEL_ALERTS=sentinel-alerts
SLACK_CHANNEL_REPORTS=sentinel-reports

# ── Database (Production — PostgreSQL) ──
DATABASE_URL=postgresql://sentinel:your_password@localhost:5432/sentinel_v3
POSTGRES_PASSWORD=your_secure_password_here

# ── Database (Development — SQLite, auto-detected via NODE_ENV) ──
SQLITE_PATH=./data/sentinel.db

# ── Scheduler ──
WEEKLY_REPORT_CRON=0 9 * * 1
